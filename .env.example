# Djangoの秘密鍵
DJANGO_SECRET_KEY=change-me-in-production

# 開発環境ではtrue、本番ではfalse
DJANGO_DEBUG=true

# Djangoがアクセスを許可するホスト
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# CSRF保護付きリクエストを許可するオリジン
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# DjangoのDB接続URL
DATABASE_URL=postgres://ns_shift:ns_shift_password@db:5432/ns_shift

# PostgresのDB名
POSTGRES_DB=ns_shift

# Postgresの接続ユーザー
POSTGRES_USER=ns_shift

# Postgresの接続パスワード
POSTGRES_PASSWORD=ns_shift_password

# コンテナ内のタイムゾーン
TZ=Asia/Tokyo
